# Application
APP_NAME=City Guide API
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/citygo

# Telegram bot
BOT_TOKEN=
BOT_WEBHOOK_SECRET=

# Telegram admin alerts for import/enrichment jobs
# TELEGRAM_BOT_TOKEN can be empty if BOT_TOKEN should be reused.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Backend URL (used by bot to call API)
BACKEND_BASE_URL=http://localhost:8000

# Public HTTPS frontend URL opened by Telegram Mini App buttons.
TELEGRAM_MINI_APP_URL=

# Default city for seed/demo
DEFAULT_CITY_SLUG=zelenogradsk

# Admin panel Bearer token (backend). Должен совпадать с VITE_ADMIN_API_TOKEN при сборке frontend.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=