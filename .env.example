# Application
APP_NAME=City Guide API
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/citygo

# Pedestrian routing. Compatible with OSRM route API.
WALKING_ROUTER_URL=https://routing.openstreetmap.de/routed-foot/route/v1/driving
WALKING_ROUTER_TIMEOUT_SECONDS=12
WALKING_ROUTER_USER_AGENT=CityGoWalkingRouter/1.0

# Place enrichment / geocoding
GEOAPIFY_API_KEY=
PLACE_ADDRESS_GEOCODER_USER_AGENT=CityGoAddressBackfill/1.0

# Telegram bot
BOT_TOKEN=
BOT_WEBHOOK_SECRET=

# Telegram admin alerts for import/enrichment jobs
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Backend URL (used by bot to call API)
BACKEND_BASE_URL=http://localhost:8000

# Public HTTPS frontend URL opened by Telegram Mini App buttons.
TELEGRAM_MINI_APP_URL=

# Default city for seed/demo
DEFAULT_CITY_SLUG=zelenogradsk

# Admin panel Bearer token. Must match VITE_ADMIN_API_TOKEN in the frontend build.
ADMIN_API_TOKEN=
