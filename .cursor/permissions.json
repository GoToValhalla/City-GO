{
  "terminalAllowlist": [
    "cd",
    "cd /Users/user/app",
    "cd /Users/user/app/frontend",
    "PYTHONPATH=/Users/user/app",
    "pytest",
    "python",
    "python3",
    "python3.11",
    "python -m pytest",
    "python3.11 -m pytest",
    "alembic",
    "npm",
    "npx",
    "vitest",
    "curl",
    "date",
    "ls",
    "mkdir",
    "cat",
    "head",
    "tail",
    "chmod",
    "rg",
    "grep",
    "bash",
    "sh",
    "ssh",
    "scp",
    "rsync",
    "docker",
    "docker compose",
    "docker compose ps",
    "docker compose logs",
    "docker compose exec",
    "docker compose build",
    "docker compose run",
    "docker compose up",
    "docker compose pull",
    "git",
    "git status",
    "git diff",
    "git log",
    "git add",
    "git commit",
    "git push",
    "git pull",
    "git fetch",
    "git checkout",
    "git branch",
    "git rebase",
    "git show",
    "git stash",
    "git merge",
    "gh",
    "gh run",
    "gh run list",
    "gh run view",
    "gh run watch",
    "gh run view --log",
    "gh run view --log-failed",
    "gh workflow",
    "gh workflow list",
    "gh workflow run",
    "gh workflow enable",
    "gh pr",
    "gh api",
    "gh run download"
  ],
  "autoRun": {
    "allow_instructions": [
      "Полная автономия: код, тесты, git commit/push, gh workflow/pr, docker, ssh, deploy — без вопросов «продолжить?».",
      "Выполнять все шаги задачи подряд. Не ждать approval между шагами.",
      "Не дублировать подтверждения в чате и в терминале."
    ],
    "block_instructions": []
  }
}
