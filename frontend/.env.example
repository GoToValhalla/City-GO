# Локальная разработка admin UI (скопируйте в .env.local, не коммитьте)
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_USE_BACKEND=true

# Должен совпадать с ADMIN_API_TOKEN в backend .env
# Сгенерировать: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
VITE_ADMIN_API_TOKEN=
VITE_MAP_STYLE_URL=
VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=© OpenStreetMap contributors
VITE_LOCATION_TTL_SECONDS=900
